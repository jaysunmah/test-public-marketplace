{
  "$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
  "name": "test-marketplace",
  "description": "Private test marketplace for development and testing of Claude Code plugins",
  "owner": {
    "name": "jaysunmah",
    "email": "test@example.com"
  },
  "plugins": [
    {
      "name": "test-lsp-plugin",
      "description": "Test LSP plugin for TypeScript/JavaScript language server",
      "version": "1.0.0",
      "author": {
        "name": "Test Author",
        "email": "test@example.com"
      },
      "source": "./plugins/test-lsp-plugin",
      "category": "development",
      "strict": false,
      "lspServers": {
        "typescript": {
          "command": "typescript-language-server",
          "args": ["--stdio"],
          "extensionToLanguage": {
            ".ts": "typescript",
            ".tsx": "typescriptreact",
            ".js": "javascript",
            ".jsx": "javascriptreact"
          }
        }
      }
    },
    {
      "name": "example-plugin",
      "description": "A comprehensive example plugin demonstrating all Claude Code extension options",
      "author": {
        "name": "Test Author",
        "email": "test@example.com"
      },
      "source": "./plugins/example-plugin",
      "category": "development",
      "homepage": "https://github.com/jaysunmah/test-marketplace/tree/main/plugins/example-plugin"
    },
    {
      "name": "code-review",
      "description": "Automated code review for pull requests using multiple specialized agents",
      "author": {
        "name": "Test Author",
        "email": "test@example.com"
      },
      "source": "./plugins/code-review",
      "category": "productivity",
      "homepage": "https://github.com/jaysunmah/test-marketplace/tree/main/plugins/code-review"
    },
    {
      "name": "test-integration",
      "description": "Test external integration plugin with MCP server configuration",
      "category": "productivity",
      "source": "./external_plugins/test-integration",
      "homepage": "https://github.com/jaysunmah/test-marketplace/tree/main/external_plugins/test-integration"
    },
    {
      "name": "test-2",
      "description": "Test plugin 2 for validating marketplace plugin registration",
      "author": {
        "name": "Test Author",
        "email": "test@example.com"
      },
      "source": "./plugins/test-2",
      "category": "development",
      "homepage": "https://github.com/jaysunmah/test-marketplace/tree/main/plugins/test-2"
    }
  ]
}
